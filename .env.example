# FactoryOPS Environment Variables

# Service URLs (internal Docker network)
DEVICE_SERVICE_URL=http://device-service:8000
DATA_SERVICE_URL=http://data-service:8081
RULE_ENGINE_URL=http://rule-engine-service:8002
ANALYTICS_SERVICE_URL=http://analytics-service:8003
REPORTING_SERVICE_URL=http://reporting-service:8085
DATA_EXPORT_URL=http://data-export-service:8080

# Service Name (for logging)
SERVICE_NAME=device-service

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_ROOT_PASSWORD=rootpassword

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=factoryops
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# EMQX (MQTT) Configuration
MQTT_BROKER_URL=mqtt://localhost:1883

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=telemetry
MINIO_SECURE=false

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Device Service
DEVICE_DB_HOST=mysql
DEVICE_DB_PORT=3306
DEVICE_DB_NAME=energy_device_db
DEVICE_DB_USER=root
DEVICE_DB_PASSWORD=rootpassword

# Rule Engine Service
RULE_DB_HOST=mysql
RULE_DB_PORT=3306
RULE_DB_NAME=energy_rule_db
RULE_DB_USER=root
RULE_DB_PASSWORD=rootpassword

# Analytics Service
ANALYTICS_DB_HOST=mysql
ANALYTICS_DB_PORT=3306
ANALYTICS_DB_NAME=energy_analytics_db
ANALYTICS_DB_USER=root
ANALYTICS_DB_PASSWORD=rootpassword

# Reporting Service
REPORTING_DB_HOST=mysql
REPORTING_DB_PORT=3306
REPORTING_DB_NAME=energy_reporting_db
REPORTING_DB_USER=root
REPORTING_DB_PASSWORD=rootpassword

# Data Export Service
EXPORT_DB_HOST=mysql
EXPORT_DB_PORT=3306
EXPORT_DB_NAME=energy_export_db
EXPORT_DB_USER=root
EXPORT_DB_PASSWORD=rootpassword
